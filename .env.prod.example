# Variables de entorno de producción
# Copiar a .env.prod y completar con valores reales

# Base de datos
POSTGRES_USER=internado_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=internado_uv

# Backend
SECRET_KEY=CAMBIAR_POR_SECRET_KEY_SEGURO_DE_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URLs
FRONTEND_URL=https://tu-dominio.com
BACKEND_URL=https://api.tu-dominio.com

# Email (opcional — si se configura fastapi-mail)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tu-dominio.com
MAIL_SERVER=smtp.tu-proveedor.com
