# Variables de entorno de producción
# 1) Copiar este archivo a .env.prod
# 2) Reemplazar TODO valor de ejemplo antes de desplegar

# ------------------------------------------
# Core
# ------------------------------------------
ENVIRONMENT=production
SECRET_KEY=CAMBIAR_POR_SECRET_KEY_MUY_SEGURA
ACCESS_TOKEN_EXPIRE_MINUTES=60
TUTOR_LOGBOOK_VALIDATION_ALERT_WEEKS=2

# ------------------------------------------
# Base de datos
# ------------------------------------------
POSTGRES_USER=internado_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
POSTGRES_DB=internado_uv

# ------------------------------------------
# URLs públicas
# ------------------------------------------
FRONTEND_URL=https://tu-dominio.com
BACKEND_URL=https://api.tu-dominio.com

# ------------------------------------------
# Frontend (build-time, Vite)
# ------------------------------------------
VITE_API_URL=https://api.tu-dominio.com
VITE_KEYCLOAK_URL=https://auth.tu-dominio.com
VITE_KEYCLOAK_REALM=internado-uv
VITE_KEYCLOAK_CLIENT_ID=internado-frontend

# ------------------------------------------
# Backend - Keycloak
# ------------------------------------------
KEYCLOAK_SERVER_URL=https://auth.tu-dominio.com
KEYCLOAK_REALM=internado-uv
KEYCLOAK_CLIENT_ID=internado-backend
KEYCLOAK_CLIENT_SECRET=CAMBIAR_CLIENT_SECRET
KEYCLOAK_REDIRECT_URI=https://tu-dominio.com/callback
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CAMBIAR_ADMIN_PASSWORD
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# ------------------------------------------
# reCAPTCHA
# ------------------------------------------
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=CAMBIAR_RECAPTCHA_SECRET

# ------------------------------------------
# Email (opcional)
# ------------------------------------------
MAIL_SERVER=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tu-dominio.com
MAIL_USE_TLS=true
