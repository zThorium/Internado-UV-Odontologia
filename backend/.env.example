# ==========================================
# Base de datos
# ==========================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/internado_uv

# ==========================================
# Autenticación JWT (Legacy - compatibilidad)
# ==========================================
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# Keycloak (FASE 1 - IAM)
# ==========================================
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=internado-uv
KEYCLOAK_CLIENT_ID=internado-backend
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:5173/callback

# ==========================================
# MinIO (FASE 2 - Object Storage)
# ==========================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# ==========================================
# Redis (FASE 3 - Cache + Queue)
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# Celery (FASE 3 - Background Jobs)
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==========================================
# MailHog (FASE 3 - Email Development)
# ==========================================
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@internado-uv.cl
MAIL_USE_TLS=false

# ==========================================
# reCAPTCHA v2
# ==========================================
RECAPTCHA_SECRET_KEY=6Ldh5pksAAAAAMF8OQwyLQi00Q126kxh50iDN_IN
RECAPTCHA_ENABLED=true

# ==========================================
# HashiCorp Vault (FASE 3 - Secrets)
# ==========================================
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ==========================================
# Sentry (FASE 2 - Error Tracking)
# ==========================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==========================================
# Prometheus (FASE 2 - Monitoring)
# ==========================================
PROMETHEUS_ENABLED=true
METRICS_ENDPOINT=/metrics

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=["http://localhost:5173"]

# ==========================================
# Environment
# ==========================================
ENVIRONMENT=development
